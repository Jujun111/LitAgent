# Copy to llm_service/.llamacpp-vision.env and adjust if needed.
# Defaults use one unified Qwen3.5-9B llama.cpp VLM server on port 8080.

LITAGENT_VISION_HOST=127.0.0.1
LITAGENT_VISION_PORT=8080
LITAGENT_VISION_API_KEY=llama-cpp
LITAGENT_VISION_MODEL_ALIAS=qwen3.5-9b-vlm

# Keep binaries and model weights out of git. The server path is relative to the repo root by default.
LITAGENT_VISION_SERVER=tools/llama.cpp/llama-server.exe

# Preferred local-file path: Qwen3.5 is natively multimodal, but llama.cpp still loads
# the vision projector as a separate mmproj GGUF file.
LITAGENT_VISION_MODEL=models/Qwen3.5-9B-Q4_K_M.gguf
LITAGENT_VISION_MMPROJ=models/mmproj-F16.gguf

# Alternative download path: set this to a repo that bundles model + mmproj, then leave
# LITAGENT_VISION_MODEL and LITAGENT_VISION_MMPROJ empty.
# Example: jc-builds/Qwen3.5-9B-VLM-Q4_K_M-GGUF
LITAGENT_VISION_HF_REPO=

# Conservative sequential-GPU defaults for RTX 4060 Laptop 8GB VRAM.
LITAGENT_VISION_CTX_SIZE=4096
LITAGENT_VISION_GPU_LAYERS=999
LITAGENT_VISION_THREADS=8
LITAGENT_VISION_IMAGE_MAX_TOKENS=1024

# Optional extra llama-server flags, for example:
# LITAGENT_VISION_EXTRA_ARGS=--verbose
LITAGENT_VISION_EXTRA_ARGS=
