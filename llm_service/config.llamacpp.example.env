# Copy to llm_service/.llamacpp.env and adjust paths if needed.
# These defaults target a local llama.cpp server with the Qwen3.5 GGUF model.

LITAGENT_LLAMA_HOST=127.0.0.1
LITAGENT_LLAMA_PORT=8080
LITAGENT_LLAMA_API_KEY=llama-cpp
LITAGENT_LLAMA_MODEL_ALIAS=qwen3.5-9b-q4km

# Keep binaries and model weights out of git. Both paths are relative to the repo root by default.
LITAGENT_LLAMA_SERVER=tools/llama.cpp/llama-server.exe
LITAGENT_LLAMA_MODEL=models/Qwen3.5-9B-Q4_K_M.gguf

# Conservative defaults for RTX 4060 Laptop 8GB VRAM.
LITAGENT_LLAMA_CTX_SIZE=4096
LITAGENT_LLAMA_GPU_LAYERS=999
LITAGENT_LLAMA_THREADS=8

# Optional extra llama-server flags, for example:
# LITAGENT_LLAMA_EXTRA_ARGS=--verbose
LITAGENT_LLAMA_EXTRA_ARGS=
