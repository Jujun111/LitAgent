# Copy this file to llm_service/.env or source it before starting vLLM.
# The defaults target the course microservice contract used by streamlit_app.py.

LITAGENT_VLLM_HOST=127.0.0.1
LITAGENT_VLLM_PORT=8000
LITAGENT_VLLM_API_KEY=token-abc123

# Qwen3.5-9B Q4_K_M GGUF. Override these if the 9B model is too tight for your GPU.
LITAGENT_VLLM_MODEL=jc-builds/Qwen3.5-9B-Q4_K_M-GGUF:Q4_K_M
LITAGENT_VLLM_TOKENIZER=Qwen/Qwen3.5-9B
LITAGENT_VLLM_HF_CONFIG_PATH=Qwen/Qwen3.5-9B

# Conservative defaults for an 8GB VRAM laptop GPU.
LITAGENT_VLLM_MAX_MODEL_LEN=4096
LITAGENT_VLLM_GPU_MEMORY_UTILIZATION=0.85
LITAGENT_VLLM_DTYPE=auto
LITAGENT_VLLM_TIMEOUT_SECONDS=60

# Optional extra vLLM CLI flags, for example:
# LITAGENT_VLLM_EXTRA_ARGS="--trust-remote-code"
LITAGENT_VLLM_EXTRA_ARGS=
